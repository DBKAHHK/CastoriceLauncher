<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="LauncherApp.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">
    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <LinearGradientBrush x:Key="StartButtonBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFF1FF8D" Offset="0" />
                <GradientStop Color="#FFD7F06A" Offset="0.45" />
                <GradientStop Color="#FFB7DF54" Offset="1" />
            </LinearGradientBrush>
            <Style x:Key="GlassSquareButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#66FFFFFF" />
                <Setter Property="BorderBrush" Value="#AAFFFFFF" />
                <Setter Property="BorderThickness" Value="1.2" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Foreground" Value="#FF0E1324" />
                <Setter Property="Padding" Value="12,8" />
            </Style>
        </Grid.Resources>

        <Image
            Stretch="UniformToFill"
            Opacity="0.9"
            Source="ms-appx:///Assets/DefaultBackground.webp" />

        <Rectangle Fill="#550D1230" />

        <Grid RowDefinitions="Auto,*,Auto" Padding="18">
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Castorice Launcher" FontSize="36" FontWeight="Bold" Foreground="#FF6EF1D6" />
                        <TextBlock x:Name="SubTitleText" Text="By Local Mode" Foreground="#E0FFFFFF" />
                    </StackPanel>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#66352558"
                    CornerRadius="14"
                    Padding="18,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="TopHomeButton" Style="{StaticResource GlassSquareButtonStyle}" Content="Home" Click="OnHomeClicked" />
                        <Button x:Name="TopToolsButton" Style="{StaticResource GlassSquareButtonStyle}" Content="Tools" Click="OnToolsClicked" />
                        <Button x:Name="TopPluginsButton" Style="{StaticResource GlassSquareButtonStyle}" Content="Plugins" Click="OnPluginsClicked" />
                        <Button x:Name="TopHowToButton" Style="{StaticResource GlassSquareButtonStyle}" Content="How to?" Click="OnHowToClicked" />
                        <Button x:Name="TopAboutButton" Style="{StaticResource GlassSquareButtonStyle}" Content="About" Click="OnAboutClicked" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="#66213A78"
                    CornerRadius="14"
                    Padding="10,6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="TopSettingsButton" Style="{StaticResource GlassSquareButtonStyle}" Click="OnOpenSettingsClicked" ToolTipService.ToolTip="设置">
                            <FontIcon Glyph="&#xE713;" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1">
                <TextBlock
                    x:Name="WelcomeText"
                    Margin="0,28,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Text="Welcome"
                    FontSize="56"
                    FontWeight="Bold"
                    Foreground="White" />

                <StackPanel
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,26"
                    Orientation="Horizontal"
                    Spacing="12">
                    <Button
                        x:Name="LeftToolsButton"
                        Style="{StaticResource GlassSquareButtonStyle}"
                        Width="78"
                        Height="78"
                        Padding="0"
                        Click="OnOpenSrToolsClicked"
                        ToolTipService.ToolTip="srtools.neonteam.dev">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE774;" FontSize="24" />
                            <TextBlock x:Name="LeftToolsText" Text="Tools" FontSize="12" />
                        </StackPanel>
                    </Button>

                    <Button
                        x:Name="LeftDiscordButton"
                        Style="{StaticResource GlassSquareButtonStyle}"
                        Width="78"
                        Height="78"
                        Padding="0"
                        Click="OnOpenDiscordClicked"
                        ToolTipService.ToolTip="discord.gg/CastoicePS">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                            <FontIcon Glyph="&#xE8BD;" FontSize="24" />
                            <TextBlock x:Name="LeftDiscordText" Text="Discord" FontSize="12" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    Padding="10"
                    Background="#55331D64"
                    CornerRadius="18">
                    <StackPanel Spacing="10">
                        <Button x:Name="RightSettingsButton" Style="{StaticResource GlassSquareButtonStyle}" Width="78" Height="78" Click="OnOpenSettingsClicked" ToolTipService.ToolTip="设置">
                            <FontIcon Glyph="&#xE70F;" />
                        </Button>
                        <Button x:Name="RightPatchButton" Style="{StaticResource GlassSquareButtonStyle}" Width="78" Height="78" Click="OnOpenPatchFolderClicked" ToolTipService.ToolTip="补丁目录">
                            <FontIcon Glyph="&#xE8B7;" />
                        </Button>
                        <Button x:Name="RightStatusButton" Style="{StaticResource GlassSquareButtonStyle}" Width="78" Height="78" Click="OnShowStatusClicked" ToolTipService.ToolTip="状态">
                            <FontIcon Glyph="&#xE946;" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Bottom">
                <Border
                    Grid.Column="0"
                    Margin="0,0,16,0"
                    Background="#66000000"
                    CornerRadius="10"
                    Padding="12,10"
                    MaxWidth="860">
                    <TextBlock
                        x:Name="StatusText"
                        Foreground="White"
                        TextWrapping="Wrap"
                        Text="就绪" />
                </Border>

                <Button
                    x:Name="PrimaryActionButton"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Padding="28,14"
                    CornerRadius="14"
                    Background="{StaticResource StartButtonBackgroundBrush}"
                    Foreground="#FF0B1225"
                    Click="OnPrimaryActionClicked">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE768;" FontSize="30" />
                        <StackPanel Spacing="0">
                            <TextBlock
                                x:Name="PrimaryActionTitleText"
                                Text="Start Game"
                                FontSize="22"
                                FontWeight="Bold" />
                            <TextBlock
                                x:Name="PrimaryActionSubText"
                                Text="Local Patch Launch"
                                FontSize="12"
                                Opacity="0.72" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button
                    x:Name="QuickMenuButton"
                    Style="{StaticResource GlassSquareButtonStyle}"
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    Width="68"
                    Height="68"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    FontSize="24"
                    Click="OnOpenQuickMenuClicked"
                    Content="☰" />
            </Grid>
        </Grid>
    </Grid>
</Page>
